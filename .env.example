# ─── Amanteech Bot v5 — Environment Variables Template ───
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to Git.

# ── REQUIRED ──────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=

# Your PERSONAL Telegram user ID (NOT the bot token prefix!)
# Get it by messaging @userinfobot on Telegram
ADMIN_ID=

# ── OPTIONAL (enables extra features) ─────────────────────
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_KEY=

# https://platform.openai.com/api-keys
OPENAI_KEY=

# https://developers.google.com/safe-browsing
SAFE_BROWSING_KEY=

# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# ── DEPLOYMENT (Railway / VPS with webhook) ────────────────
# Leave blank to use polling (local/dev mode)
# Set to your public HTTPS domain for production webhook mode
# Example: https://your-app.up.railway.app
WEBHOOK_URL=
STRIPE_WEBHOOK_SECRET=

# Port the webhook server will listen on (Railway sets this automatically)
PORT=8080